# MongoDB Configuration
# Option 1: MongoDB Atlas (Recommended for production)
# Get your connection string from: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/chronic_care?retryWrites=true&w=majority
MONGODB_URI=

# Option 2: Local MongoDB
# MONGODB_URI=mongodb://localhost:27017/chronic_care

# Option 3: Memory DB (default, for development only)
# Leave MONGODB_URI empty and set USE_MEMORY_DB=true
USE_MEMORY_DB=false

# JWT Secret (generate a strong random string)
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:3005

# WeChat Configuration
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret
WECHAT_TOKEN=your-wechat-token
WECHAT_ENCODING_AES_KEY=your-encoding-aes-key
WECHAT_MEDICATION_TEMPLATE_ID=your-medication-template-id
WECHAT_APPOINTMENT_TEMPLATE_ID=your-appointment-template-id
WECHAT_ALERT_TEMPLATE_ID=your-alert-template-id
WECHAT_SUMMARY_TEMPLATE_ID=your-summary-template-id

# Bcrypt Salt Rounds
BCRYPT_SALT_ROUNDS=12
